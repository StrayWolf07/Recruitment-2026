# ---- Database ----
# Production / Postgres (Railway, Neon, etc.):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Local dev with SQLite (use schema.sqlite.prisma and db:generate:dev):
# DATABASE_URL="file:./dev.db"

# ---- Auth ----
# Fallback admin login if Admin table lookup fails
ADMIN_USER="admin"
ADMIN_PASS="admin123"
SESSION_SECRET="your-secret-key-change-in-production"

# ---- Cloudflare R2 (production file uploads) ----
# Leave unset for local dev (files stored on disk). Set all for presigned uploads.
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=exam-uploads
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Public URL for download links (custom domain or R2 public bucket URL)
# R2_PUBLIC_BASE_URL=https://uploads.yourdomain.com
# Optional: max upload size in bytes (default 52428800 = 50MB)
# MAX_UPLOAD_BYTES=52428800

# ---- Optional ----
# APP_BASE_URL=https://your-app.railway.app
