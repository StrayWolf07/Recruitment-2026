// Use this schema for local development with SQLite.
// Run: npx prisma generate --schema=prisma/schema.sqlite.prisma
// Set DATABASE_URL="file:./dev.db" in .env
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  gender       String?
  college      String?
  degree       String?
  branch       String?
  cgpa         Float?
  contactNumber    String?
  emailId          String?
  age              Int?
  location         String?
  source           String?
  readyToRelocate  String?
  fatherName   String?
  motherName   String?
  brotherName  String?
  sisterName   String?
  spouseName   String?
  childrenName String?
  graduation             String?
  engineering            String?
  masters                String?
  pgDiploma              String?
  additionalQualifications String?
  presentOrganization   String?
  designation           String?
  currentJobDetails     String?
  teamSizeHandled       String?
  reportingTo           String?
  currentMonthlyCTC    String?
  currentAnnualCTC     String?
  expectedMonthlyCTC   String?
  expectedAnnualCTC    String?
  totalExperience      String?
  noticePeriod         String?
  reasonsForChange     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  profiles     StudentProfile[]
  examSessions ExamSession[]
}

model StudentProfile {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name      String?
  gender    String?
  college   String?
  degree    String?
  branch    String?
  cgpa      Float?
  roleIds   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Role {
  id                String             @id @default(cuid())
  name              String
  description       String?
  isActive          Boolean            @default(true)
  theoryQuestions   TheoryQuestion[]
  practicalQuestions PracticalQuestion[]
  examQuestions     ExamQuestion[]
}

model TheoryQuestion {
  id           String   @id @default(cuid())
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  questionText String
  isActive     Boolean  @default(true)
}

model PracticalQuestion {
  id           String   @id @default(cuid())
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  questionText String
  isActive     Boolean  @default(true)
}

model ExamSession {
  id                String       @id @default(cuid())
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  roleIds           String
  phase             String       @default("theory")
  startTime         DateTime
  endTime           DateTime
  submittedAt       DateTime?
  theoryTabViolation  Boolean      @default(false)
  terminationReason   String?
  terminatedAt        DateTime?
  totalScore          Int?
  evaluationStatus  String       @default("pending")
  evaluatedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  examQuestions     ExamQuestion[]
  answers           Answer[]
  examLogs          ExamLog[]
  practicalFiles    PracticalFile[]
}

model ExamQuestion {
  id            String       @id @default(cuid())
  sessionId     String
  session       ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  roleId        String
  role          Role         @relation(fields: [roleId], references: [id])
  section       String
  questionType  String
  questionText  String
  sourceId      String?
  orderIndex    Int
  createdAt     DateTime     @default(now())
  answers       Answer[]
}

model Answer {
  id              String       @id @default(cuid())
  sessionId       String
  session         ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  examQuestionId  String
  examQuestion    ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)
  @@unique([sessionId, examQuestionId])
  answerText      String?
  firstOpened     DateTime?
  firstTyped      DateTime?
  lastModified    DateTime?
  totalTimeSpent   Int          @default(0)
  scoreAwarded     Int?
  openedAt         DateTime?
  lastOpenedAt     DateTime?
  closedAt         DateTime?
  activeTimeMs     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ExamLog {
  id              String       @id @default(cuid())
  sessionId       String
  session         ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType       String
  timestamp       DateTime
  duration        Int?
  metadata        String?
  createdAt       DateTime     @default(now())
}

model PracticalFile {
  id          Int         @id @default(autoincrement())
  sessionId   String
  questionId  String
  filename    String
  storedPath  String
  mimeType    String?
  sizeBytes   Int
  uploadedAt  DateTime     @default(now())
  session     ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
